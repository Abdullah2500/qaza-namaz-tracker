# Copy this file to ".env" and fill in your Supabase project values.
# The app works fully offline (localStorage) even without these set —
# they only enable cross-device cloud sync + sign in.
#
# Find these in your Supabase dashboard:
#   Project Settings -> API -> Project URL and Project API keys (anon/public)

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
